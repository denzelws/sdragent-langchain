{
  "name": "gmail-ollama-sdr-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Gmail + Ollama SDR drafting agent for safe development.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "auth:gmail": "tsx src/auth.ts",
    "typecheck": "tsc --noEmit",
    "state:clear": "rm -rf .agent-state",
    "test:meeting:001": "tsx src/index.ts --query \"from:sanmutty@gmail.com subject:MEETING_TEST_001 newer_than:7d\" --max 1",
    "test:meeting:002": "tsx src/index.ts --query \"from:sanmutty@gmail.com subject:MEETING_TEST_002 newer_than:7d\" --max 1",
    "test:meeting:003": "tsx src/index.ts --query \"from:sanmutty@gmail.com subject:MEETING_TEST_003 newer_than:7d\" --max 1",
    "test:meeting:batch": "tsx src/index.ts --query \"from:sanmutty@gmail.com subject:MEETING_TEST newer_than:7d\" --max 3",
    "test:product-faq:001": "tsx src/index.ts --query \"from:sanmutty@gmail.com newer_than:7d\" --max 1",
    "notion:prospects": "tsx src/prospects/runNotionProspectLogger.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.75",
    "@langchain/ollama": "^0.2.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.7",
    "googleapis": "^144.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
