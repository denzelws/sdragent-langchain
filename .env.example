OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
SENDER_NAME=Denzel

GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json
GMAIL_QUERY=in:inbox newer_than:7d

MAX_EMAILS=10
WORKFLOW_MODE=all
SKIP_PROCESSED_EMAILS=true
PROCESSED_EMAIL_STORE_PATH=./.agent-state/processed-emails.json

DRY_RUN=true
CREATE_DRAFTS=false
REQUIRE_DRAFT_APPROVAL=true

SEND_APPROVED_DRAFTS=false
REQUIRE_SEND_APPROVAL=true

# Meeting invitation workflow
ENABLE_MEETING_WORKFLOW=false
CREATE_CALENDAR_EVENTS=false
REQUIRE_CALENDAR_EVENT_APPROVAL=true
DEFAULT_TIMEZONE=America/Sao_Paulo

# Debugging
DEBUG_LLM_OUTPUT=false
